# Database Configuration
# Set to 'mysql' or 'postgresql'
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=crypto_bi_db
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# CoinGecko API Configuration
# Optional: only if you have a CoinGecko Pro API Key. If left empty, the pipeline will use the public free API.
COINGECKO_API_KEY=
